// <TargetFramework>net10.0</TargetFramework>
using System.Reflection;
var asm = Assembly.LoadFrom(
    Environment.ExpandEnvironmentVariables(@"%USERPROFILE%\.nuget\packages\fluid.core\2.31.0\lib\net9.0\Fluid.dll"));
foreach (var t in asm.GetExportedTypes().OrderBy(t => t.FullName))
{
    foreach (var m in t.GetMethods(BindingFlags.Public | BindingFlags.Static | BindingFlags.Instance)
        .Where(m => m.Name.Contains("Parse") || m.Name.Contains("Render") || m.Name.Contains("TryParse"))
        .Take(5))
        Console.WriteLine($"{t.FullName}.{m.Name}({string.Join(", ", m.GetParameters().Select(p => $"{p.ParameterType.Name} {p.Name}"))})");
    if (t.GetMethods().Any(m => m.Name.Contains("Parse") || m.Name.Contains("TryParse") || m.Name.Contains("Render")))
        Console.WriteLine();
}
